{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Principal": {
        "Service": "s3.amazonaws.com"
      },
      "Action": "SNS:Publish",
      "Resource": "arn:aws:sns:us-east-1:518216637063:image-upload-notifications",
      "Condition": {
        "StringEquals": {
          "aws:SourceAccount": "518216637063"
        },
        "ArnLike": {
          "aws:SourceArn": "arn:aws:s3:::cc-images-yuw420"
        }
      }
    }
  ]
}